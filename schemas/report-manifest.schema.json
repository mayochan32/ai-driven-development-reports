{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/report-manifest.schema.json",
  "title": "Report Manifest",
  "type": "object",
  "required": ["id", "title", "status", "date", "tags", "readme", "markdown", "html"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9]{3}-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "published", "archived"]
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string"
    },
    "readme": {
      "type": "string"
    },
    "markdown": {
      "type": "string"
    },
    "html": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
